{
  "name": "cadence",
  "version": "0.1.0",
  "description": "Open-source pronunciation training with AI feedback, guided speaking modules, and an open-topic coach.",
  "license": "MIT",
  "private": false,
  "author": "Pavel Stepanov",
  "homepage": "https://github.com/pstepanovum/Cadence",
  "repository": {
    "type": "git",
    "url": "https://github.com/pstepanovum/Cadence.git"
  },
  "bugs": {
    "url": "https://github.com/pstepanovum/Cadence/issues"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "pronunciation",
    "accent-training",
    "speech",
    "ai",
    "education",
    "supabase",
    "stripe",
    "language-learning",
    "text-to-speech",
    "speech-recognition"
  ],
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:all": "node ./scripts/dev-all.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:cloud": "node ./scripts/db-cloud.mjs",
    "db:cloud:clear": "node ./scripts/db-cloud.mjs --clear",
    "db:cloud:clear-force": "node ./scripts/db-cloud.mjs --clear-force",
    "db:cloud:reset": "node ./scripts/db-cloud.mjs --reset",
    "db:cloud:reset-force": "node ./scripts/db-cloud.mjs --reset --clear-force",
    "db:cloud:modules": "npx supabase db query -f supabase/modules.sql --linked",
    "db:cloud:conversation": "npx supabase db query -f supabase/conversation.sql --linked"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "griddy-icons": "^0.2.0",
    "lenis": "^1.3.21",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
